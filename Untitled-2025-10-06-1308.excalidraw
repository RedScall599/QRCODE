      "isDeleted": false,
      "boundElements": [],
      "updated": 1742688002000,
      "link": null,
      "locked": false,
      "text": "Problem Statement:",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem Statement:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ps_p1",
      "type": "text",
      "x": 9015,
      "y": -2508,
      "width": 1020,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "z0205",
      "roundness": null,
      "seed": 1306861,
      "version": 1,
      "versionNonce": 1250029,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742688002000,
      "link": null,
      "locked": false,
      "text": "Users currently have no centralized platform to generate, save, and\nmanage QR codes. Codes must be recreated from scratch each time with\nno account system, labels, or persistent storage to track them.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Users currently have no centralized platform to generate, save, and\nmanage QR codes. Codes must be recreated from scratch each time with\nno account system, labels, or persistent storage to track them.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ps_p2",
      "type": "text",
      "x": 9015,
      "y": -2413,
      "width": 1020,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "z0206",
      "roundness": null,
      "seed": 91884,
      "version": 1,
      "versionNonce": 1323835,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742688002000,
      "link": null,
      "locked": false,
      "text": "Third-party QR tools provide no way to organize, label, or re-download\ncodes over time, leading to a fragmented and inefficient experience for\nusers who depend on QR codes regularly.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Third-party QR tools provide no way to organize, label, or re-download\ncodes over time, leading to a fragmented and inefficient experience for\nusers who depend on QR codes regularly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ps_p3",
      "type": "text",
      "x": 9015,
      "y": -2318,
      "width": 1020,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "z0207",
      "roundness": null,
      "seed": 5307,
      "version": 1,
      "versionNonce": 1696832,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742688002000,
      "link": null,
      "locked": false,
      "text": "A user-authenticated web platform with QR code generation from URLs\nand image files, persistent database storage, and a history dashboard\nis needed to streamline the workflow and improve usability.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A user-authenticated web platform with QR code generation from URLs\nand image files, persistent database storage, and a history dashboard\nis needed to streamline the workflow and improve usability.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "sc_l",
      "type": "text",
      "x": 9015,
      "y": -2200,
      "width": 1020,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "z0208",
      "roundness": null,
      "seed": 1204278,
      "version": 1,
      "versionNonce": 768087,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1742688002000,
      "link": null,
      "locked": false,
      "text": "Screens to Build:\n1. Sign Up / Sign In       — Email + password authentication\n2. QR Code Generator  — URL & image input, size/colour/error controls, live canvas preview\n3. QR Code History       — Grid of saved codes with label, date saved, and download button",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Screens to Build:\n1. Sign Up / Sign In       — Email + password authentication\n2. QR Code Generator  — URL & image input, size/colour/error controls, live canvas preview\n3. QR Code History       — Grid of saved codes with label, date saved, and download button",
      "autoResize": false,
      "lineHeight": 1.25
    },
