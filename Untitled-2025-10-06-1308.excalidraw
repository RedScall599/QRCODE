      "isDeleted": false,
      "boundElements": [],
      "updated": 1742688002000,
      "link": null,
      "locked": false,
      "text": "• Framework:  Next.js 15  (App Router)\n• Database:    PostgreSQL  via Prisma ORM\n• Auth:           Custom session token  (HTTP-only cookie)\n• Storage:      /public/uploads  directory\n• QR Library: qrcode  (npm)\n• Styling:       Tailwind CSS\n• Deployment: Docker  +  AWS EC2",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• Framework:  Next.js 15  (App Router)\n• Database:    PostgreSQL  via Prisma ORM\n• Auth:           Custom session token  (HTTP-only cookie)\n• Storage:      /public/uploads  directory\n• QR Library: qrcode  (npm)\n• Styling:       Tailwind CSS\n• Deployment: Docker  +  AWS EC2",
      "autoResize": false,
      "lineHeight": 1.25
    },
